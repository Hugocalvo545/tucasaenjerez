rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ========= HELPERS ========= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in [
          "9YsZ5CGjQLRHsP055UwxzB7yMsa2"
        ]
        ||
        request.auth.token.email in [
          "hugocalvogarcia123@gmail.com"
        ]
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function onlyUpdates(keys) {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasOnly(keys);
    }

    // Un update NO debe tocar campos de fidelidad: points/nivel solo los escribe el servidor
    // (Admin SDK, que se salta estas reglas). Robusto ante docs viejos sin el campo.
    function touchesFidelity() {
      return request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(["points", "nivel", "level"]);
    }

    /* ========= USUARIOS ========= */

    match /usuarios/{userId} {
      allow read: if isOwner(userId);

      // Alta del propio doc al registrarse: points debe empezar en 0 o ausente. Cierra el
      // ataque E también por la vía del create (set con points:999999 en doc nuevo).
      allow create: if isOwner(userId)
        && (!("points" in request.resource.data) || request.resource.data.points == 0);

      // Edición de perfil por el dueño: nombre/contacto sí, points/nivel NUNCA.
      allow update: if isOwner(userId) && !touchesFidelity();

      allow delete: if isOwner(userId);

      match /huespedes_frecuentes/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    /* ========= APARTAMENTOS ========= */

    match /apartamentos/{aptoId} {
      allow read: if true;
      allow write: if isAdmin();

      match /prices/{dateId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /* ========= PACKS ========= */

    match /packs/{packId} {
      allow read: if true;
      allow write: if isAdmin();

      match /prices/{dateId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    /* ========= RESERVAS PUBLICAS (CALENDARIO) ========= */

    match /reservas_public/{id} {
      allow read: if true;

      // La Cloud Function escribe con Admin SDK (bypass de rules),
      // pero dejamos esto para compatibilidad con el flujo antiguo si lo necesitas.
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.reservaId == id
        && request.resource.data.propertyId is string
        && request.resource.data.checkInISO is string
        && request.resource.data.checkOutISO is string;

      allow update: if isAdmin();

      // El propietario de la reserva puede eliminar su bloqueo de fechas al cancelar.
      allow delete: if isAdmin()
        || (isSignedIn()
          && get(/databases/$(database)/documents/reservas/$(id)).data.userId == request.auth.uid);
    }

    /* ========= RESERVAS PRIVADAS ========= */

    match /reservas/{reservaId} {

      // resource == null cuando el documento no existe todavía (polling pre-webhook):
      // devolver "not found" a un usuario autenticado no expone datos.
      allow read: if isSignedIn()
        && (resource == null || resource.data.userId == request.auth.uid || isAdmin());

      // El cliente NO crea reservas: todo pasa por createCheckoutSession → webhook (Admin SDK,
      // que se salta estas reglas). El "hold" de fechas vive en /holds y el pending en
      // /pending_bookings, no aquí. Cierra el ataque A (reserva fantasma confirmed/paid/total:0).
      allow create: if false;

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.userId
        && onlyUpdates(["observations"]);

      // El huésped puede cancelar su propia reserva.
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.userId
        && onlyUpdates(["status", "cancelledAt"])
        && request.resource.data.status == "cancelled";

      allow update, delete: if isAdmin();
    }

    /* ========= RESERVAS PENDIENTES (pre-pago Stripe) ========= */

    match /pending_bookings/{id} {
      // El usuario puede leer su propia reserva pendiente (para la página de éxito)
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Solo la Cloud Function escribe (Admin SDK — bypass automático)
      allow write: if false;
    }

    /* ========= HOLDS ========= */

    match /holds/{holdId} {

      allow read: if true;

      // 16 minutos en las rules para absorber desfase de reloj y latencia de red
      // (el cliente crea el hold con 14m50s para estar siempre por debajo)
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <=
           request.time + duration.value(16, "m");

      allow delete: if
        (isSignedIn() && request.auth.uid == resource.data.userId)
        || (resource.data.expiresAt <= request.time)
        || isAdmin();

      allow update: if false;
    }

    /* ========= BLOQUEOS (INTRANET) ========= */

    match /bloqueos/{bloqueoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ========= TOKENS DISPOSITIVOS ========= */

    match /deviceTokens/{tokenId} {
      allow read, write: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    /* ========= CHAT ========= */

    match /chats/{chatId} {

      allow read: if isAdmin()
        || (isSignedIn()
          && request.auth.uid == get(
            /databases/$(database)/documents/reservas/$(chatId)
          ).data.userId
        );

      allow write: if isAdmin();

      // El dueño de la reserva puede marcar SOLO unreadHost en SU chat (al enviar mensaje).
      // El doc padre /chats/{chatId} no lo crea el webhook, así que el primer .set(merge) del
      // huésped puede ser un create: se permite acotado a que el doc contenga solo unreadHost.
      // No reabre nada: cualquier otro campo (lastMessage, unreadGuest, etc.) → denegado.
      allow create: if isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/reservas/$(chatId)).data.userId
        && request.resource.data.keys().hasOnly(["unreadHost", "unreadGuest"]);
      allow update: if isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/reservas/$(chatId)).data.userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["unreadHost", "unreadGuest"]);

      match /mensajes/{mensajeId} {

        allow read: if isAdmin()
          || (isSignedIn()
            && request.auth.uid == get(
              /databases/$(database)/documents/reservas/$(chatId)
            ).data.userId
          );

        allow create: if isSignedIn()
          && (
            isAdmin()
            || request.auth.uid == get(
              /databases/$(database)/documents/reservas/$(chatId)
            ).data.userId
          );

        allow update, delete: if isAdmin();
      }
    }

    /* ========= REVIEWS / COMENTARIOS ========= */

    match /reviews/{reviewId} {
      allow read: if true;

      // Admin puede hacer todo sin restricciones (seed, moderación, etc.)
      allow write: if isAdmin();

      // Usuario autenticado puede crear reseña si la reserva le pertenece
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.reservaId is string
        && get(/databases/$(database)/documents/reservas/$(request.resource.data.reservaId)).data.userId == request.auth.uid;
    }

    /* ========= REGISTRO DE VIAJEROS (Orden INT/1922/2003) ========= */

    match /registro_viajeros/{registroId} {
      allow read: if isAdmin();
      allow write: if false;  // solo Admin SDK del webhook
    }

    /* ========= CONFIGURACIÓN (INTRANET) ========= */

    // Ajustes editables desde la intranet (p.ej. /config/ses → código de establecimiento
    // SES.HOSPEDAJES). Solo la intranet lo consume, por eso lectura y escritura son de admin.
    match /config/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    /* ========= CORTAFUEGOS FINAL ========= */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}