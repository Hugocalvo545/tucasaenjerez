{
  "firestore": {
    "database": "(default)",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": [
    {
      "target": "main",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/auth-bridge.html",
          "headers": [
            { "key": "X-Frame-Options", "value": "ALLOW-FROM https://tucasaenjerez.com" },
            { "key": "Content-Security-Policy", "value": "frame-ancestors https://tucasaenjerez.com" }
          ]
        },
        {
          "source": "/sw.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
            { "key": "Service-Worker-Allowed", "value": "/" }
          ]
        },
        {
          "source": "/firebase-messaging-sw.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "**/*.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "**/*.css",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "**/*.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        }
      ]
    },
    {
      "target": "admin",
      "public": "public-admin",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/intranet/service-worker.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
            { "key": "Service-Worker-Allowed", "value": "/" }
          ]
        },
        {
          "source": "**/*.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "**/*.css",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        },
        {
          "source": "**/*.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, must-revalidate" }]
        }
      ]
    }
  ]
}